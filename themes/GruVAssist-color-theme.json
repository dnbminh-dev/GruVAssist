        "editorLineNumber.activeForeground":    "#D5C4A1",
        "editor.lineHighlightBackground":       "#1c1c1c",
        "editor.selectionBackground":           "#3c383680",
        "editorCursor.foreground":              "#EBDBB2",

        "activityBar.background":               "#1c1c1c",
        "activityBar.border":                   "#2a2a2a",
        "sideBar.background":                   "#1c1c1c",
        "sideBar.border":                       "#2a2a2a",
        "sideBarTitle.foreground":              "#A89984",
        "sideBarSectionHeader.background":      "#232323",

        "tab.activeBackground":                 "#161616",
        "tab.activeForeground":                 "#EBDBB2",
        "tab.activeBorder":                     "#689d6a",
        "tab.inactiveBackground":               "#1c1c1c",
        "tab.inactiveForeground":               "#665c54",
        "editorGroupHeader.tabsBackground":     "#1c1c1c",
        "editorGroupHeader.tabsBorder":         "#2a2a2a",

        "statusBar.background":                 "#1c1c1c",
        "statusBar.border":                     "#2a2a2a",
        "statusBar.foreground":                 "#A89984",
        "editorWidget.background":              "#232323",
        "editorWidget.border":                  "#3c3836",

        "activityBarBadge.background":          "#3c5a3e",
        "activityBarBadge.foreground":          "#8ec07c",
        "badge.background":                     "#3c5a3e",
        "badge.foreground":                     "#8ec07c",
        "progressBar.background":               "#689d6a",

        "titleBar.activeBackground":            "#161616",
        "titleBar.activeForeground":            "#EBDBB2",
        "titleBar.inactiveBackground":          "#161616",
        "titleBar.inactiveForeground":          "#665c54",
        "titleBar.border":                      "#2a2a2a",

        "menubar.selectionBackground":          "#3c3836",
        "menubar.selectionForeground":          "#EBDBB2",
        "menu.background":                      "#232323",
        "menu.foreground":                      "#EBDBB2",
        "menu.selectionBackground":             "#3c5a3e",
        "menu.selectionForeground":             "#8ec07c",
        "menu.border":                          "#2a2a2a",
        "menu.separatorBackground":             "#2a2a2a"
    },


    "semanticHighlighting": true,

    "semanticTokenColors": {

        // ── OPERATOR OVERLOADS ────────────────────────────────────────────────
        // operator keyword at declaration site (operator+, operator<<, etc.)
        "memberOperatorOverload:cpp": "#EBDBB2",
        "operatorOverload:cpp":       "#EBDBB2",

        // ── PUNCTUATION RESET ─────────────────────────────────────────────────
        // Prevent braces/parens from inheriting orange from operator context
        "punctuation":     "#EBDBB2",
        "punctuation:cpp": "#EBDBB2",
        "punctuation:c":   "#EBDBB2",

        // ── VARIABLES — LOCAL / GLOBAL  →  blue #9CDCFE ───────────────────────
        // cpptools emits "variable" for locals, globals, and parameters.
        // We set the base "variable" token here; "property" overrides below
        // for members, so the two never conflict.
        "variable":        "#9CDCFE",
        "variable:cpp":    "#9CDCFE",
        "variable:c":      "#9CDCFE",

        // explicit modifier variants (cpptools / clangd)
        "variable.local:cpp":   "#9CDCFE",
        "variable.local:c":     "#9CDCFE",
        "variable.global:cpp":  "#4EC9B0",
        "variable.global:c":    "#4EC9B0",

        // ── VARIABLES — MEMBER / FIELD  →  tan #dfd9c2 ────────────────────────
        // cpptools uses semantic type "property" for instance member variables.
        // clangd uses "field". Both are covered.
        // C struct fields (C) are also "property" in cpptools, "field" in clangd.

        // cpptools (ms-vscode.cpptools)
        "property:cpp":          "#dfd9c2",
        "property:c":            "#dfd9c2",
        "property.static:cpp":   "#dfd9c2",
        "property.static:c":     "#dfd9c2",

        // clangd (llvm-vs-code-extensions.vscode-clangd)
        "field:cpp":             "#dfd9c2",
        "field:c":               "#dfd9c2",
        "field.static:cpp":      "#dfd9c2",
        "field.static:c":        "#dfd9c2",

        // cpptools also emits variable.static for static members in some cases
        "variable.static:cpp":   "#dfd9c2",
        "variable.static:c":     "#dfd9c2"
    },

